# Arquivo de exemplo — renomeie para .env e preencha com suas credenciais

# ── Banco de Dados (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/retail_analytics_db

# ── Cache / Rate Limiter (Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ── Audit Logging (MongoDB) ────────────────────────────────────────────────────
MONGODB_URL=mongodb://user:password@localhost:27017
MONGODB_DB_NAME=audit_logs

# ── LLM: Google Gemini ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── LLM: AWS Bedrock (Claude) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_HAIKU_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# ── Data Warehouse (Databricks SQL Warehouse) ──────────────────────────────────
DATABRICKS_ACCESS_TOKEN=your_databricks_token_here
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# ── JWT Authentication ─────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
